{{define "title"}}Create Quiz{{end}}

{{define "main"}}
    <h2>Create a New Quiz</h2>
    <form action="/quizzes/create" method="POST">
        <div>
            <label for="skill">Skill:</label>
            {{with .Form.FieldErrors.skill}}
            <label class='error'>{{.}}</label>
        {{end}}
        
            <input type="text" name="skill" value="{{.Form.Skill}}">
        </div>
        <div>
            <label for="quiz">Quiz:</label>
            {{with .Form.FieldErrors.quiz}}
            <label class='error'>{{.}}</label>
        {{end}}
            <textarea id="quiz" name="quiz" rows="5">{{.Form.Quiz}}</textarea>
        </div>
        <div>
        <button type="submit">Create Quiz</button>
        </div>
    </form>
{{end}}